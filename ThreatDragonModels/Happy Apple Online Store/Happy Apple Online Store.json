                  "title": "Information Disclosure via verbose errors",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "type": "Information disclosure",
                  "description": "Detailed error messages or stack traces could expose internal implementation details useful to an attacker.",
                  "mitigation": "The application runs in production mode, suppressing stack traces and serving generic custom error pages.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 6,
                  "score": "5.5"
                },
                {
