                  "id": "e5ef7b7d-5ea6-443a-98cc-c69c2b6281ff",
                  "title": "Server Impersonation via MITM",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": " An attacker positioned between client and server could impersonate the application to intercept or manipulate traffic.",
                  "mitigation": " All traffic is enforced over HTTPS/TLS; HTTP Strict Transport Security (HSTS) prevents downgrade to unencrypted connections.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
