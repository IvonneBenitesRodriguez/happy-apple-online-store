                {
                  "id": "c32e5103-08ac-4015-bac0-156a66506590",
                  "title": "Parameter Tampering via Mass Assignment",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "An attacker could manipulate request parameters to set unintended attributes on a model, altering application behavior or data.",
                  "mitigation": " Rails Strong Parameters whitelist only explicitly permitted attributes for each controller action.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 4,
                  "score": "6.5"
                },
                {
                  "id": "beccf84e-263f-4d63-b06d-7581b428abf4",
                  "title": "Insufficient Security Event Logging",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Repudiation",
                  "description": "Without adequate logging of security-relevant actions, it becomes difficult to reconstruct what happened during an incident.",
                  "mitigation": "Structured logging captures security-relevant events such as authentication and authorization failures, with timestamps.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 5,
                  "score": "5.0"
                },
