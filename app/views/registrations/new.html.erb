<div class="login-container">
  <div class="login-form">
    <h1>Create your account</h1>
    <p>Join the Happy Apple family 🍎</p>

    <%= form_with model: @user, url: registrations_path do |form| %>
      <%= form.label :email_address, "E-mail" %><br>
      <%= form.email_field :email_address, required: true, 
          placeholder: "example@gmail.com" %><br>

      <%= form.label :password, "Password" %><br>
      <%= form.password_field :password, required: true, 
          placeholder: "Min. 8 characters" %><br>

      <%= form.label :password_confirmation, "Confirm password" %><br>
      <%= form.password_field :password_confirmation, required: true, 
          placeholder: "Repeat your password" %><br>

      <%= form.submit "Sign up" %>
    <% end %>

    <p>Already have an account? <%= link_to "Login", new_session_path %></p>
  </div>
</div>