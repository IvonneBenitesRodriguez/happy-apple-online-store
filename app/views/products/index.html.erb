<div class="products-header">
  <h1>Hello, <%= current_user.email_address %> 👋</h1>
  <div class="search-bar">
    <%= search_field_tag :search, params[:search], 
        placeholder: "Search...", class: "search-input" %>
  </div>
</div>

<h2>Coffee and Tea Categories ☕🍵</h2>

<div class="products-grid">
  <% @products.each do |product| %>
    <div class="product-card">
      <%= image_tag "#{product.name.parameterize}.jpg", class: "product-image" %>
      <h3><%= product.name %></h3>
      <p class="product-category"><%= product.category %></p>
      <p class="product-price">$<%= product.price %></p>
      <p class="product-benefits"><%= product.benefits %></p>
      <details class="product-details">
            <summary></summary>
            <p><%= product.description %></p>
      </details>
      <%= button_to "Add to Cart", cart_items_path(product_id: product.id), method: :post, class: "btn-cart" %>
    </div>
  <% end %>
</div>